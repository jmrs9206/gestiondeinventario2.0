# Inventory Management System - Environment Variables Template
# Copy this file to .env and adjust values for your environment.

# Database Configuration (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=stockflow_inventory
DB_USER=stockflow_user
DB_PASSWORD=stockflow_secure_password_change_me

# JWT Security Configurations
# Secret must be at least 256-bit (32 characters / bytes)
JWT_SECRET=super_secret_key_change_me_stockflow_inventory_system_at_least_32_bytes_long
JWT_EXPIRATION=3600
REFRESH_TOKEN_EXPIRATION=604800

# Default Admin User Credentials (for bootstrapping)
ADMIN_EMAIL=admin@tuempresa.com
ADMIN_PASSWORD=vd_admin_z2X4m7P1v9R8s3T5


# QR Configuration
QR_BASE_URL=https://inventario.tuempresa.com

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://127.0.0.1:8080

