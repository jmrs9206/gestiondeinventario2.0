# Inventory Management System - Environment Variables Template
# Copy this file to .env and adjust values for your environment.

# Database Configuration (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=stockflow_inventory
DB_USER=stockflow_user
DB_PASSWORD=stockflow_secure_password_change_me

# JWT Security Configurations
# Secret must be at least 256-bit (32 characters / bytes)
JWT_SECRET=super_secret_key_change_me_stockflow_inventory_system_at_least_32_bytes_long
JWT_EXPIRATION=3600
REFRESH_TOKEN_EXPIRATION=604800

# Default Admin User Credentials (for bootstrapping)
OWNER_EMAIL=admin@tuempresa.com
ADMIN_EMAIL=admin@tuempresa.com
ADMIN_PASSWORD=vd_admin_z2X4m7P1v9R8s3T5

# Outbound Email Configuration
# SMTP_USERNAME is the mailbox used to authenticate with the mail provider.
# MAIL_FROM is the visible sender used for invitations/credential recovery emails.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=noreply@tuempresa.com
SMTP_PASSWORD=change_me
MAIL_FROM=noreply@tuempresa.com
IMAP_ENABLED=true
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=noreply@tuempresa.com
# Defaults to SMTP_PASSWORD when omitted.
IMAP_PASSWORD=
IMAP_SSL_ENABLED=true

# QR Configuration
QR_BASE_URL=https://inventario.tuempresa.com

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://127.0.0.1:8080
BACKEND_URL=http://127.0.0.1:8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
